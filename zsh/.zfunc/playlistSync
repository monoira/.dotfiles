playlistSync() {
  mkdir -p ~/.config/cmus/playlists

  songs_location="$HOME/Documents/personal/songs"

  # rewrite playlist entries so they point to the real song directory
  sed -i "s|^Music/|$songs_location/|" "$songs_location"/*.m3u

  # link the playlists into cmus’s playlists directory
  ln -sf "$songs_location"/*.m3u ~/.config/cmus/playlists

  # create a GENERAL playlist with all mp3s by modification date
  ls -t "$songs_location"/*.mp3 >~/.config/cmus/playlists/PLAYLIST.m3u
}
