{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "plan",
  // "instructions": [
  //   "CONTRIBUTING.md",
  // ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false,
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false,
    },
  },
  "lsp": true,
  "formatter": {
    // using prettier instead
    "biome": {
      "disabled": true,
    },
  },
}
